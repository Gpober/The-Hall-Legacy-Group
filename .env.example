# Supabase — Hall Legacy Group (marketing site + CRM share one project)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx

# New-lead email alerts (optional). Uses Gmail SMTP with an App Password.
# Generate at https://myaccount.google.com/apppasswords (requires 2-Step Verification).
GMAIL_USER=you@thehalllegacygrp.com
GMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx
LEAD_NOTIFY_TO=you@thehalllegacygrp.com

# Google Calendar sync (optional). Use the SAME OAuth client you configure for
# "Sign in with Google" in Supabase. Needed so the server can refresh Calendar
# access tokens. (Google sign-in itself is configured in the Supabase dashboard.)
GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxxxxxx

# Optional: password-gate the public marketing site. Set to enable; unset = public.
SITE_PASSWORD=
